import "primitives/core.futil";

component example() -> (out: 8) {
  cells {
    r0 = std_reg(8);
    r1 = std_reg(8);
  }
  wires {
    out = r1.out;
  }
  control {
    seq {
      invoke r0(in = 8'd1)();
      invoke r1(in = 8'd5)();
    }
  }
}

component main() -> () {
  cells {
    ex = example();
  }
  wires {
    group g {
      ex.go = 1'd1;
      g[done] = ex.done;
    }
  }
  control {
    g;
  }
}