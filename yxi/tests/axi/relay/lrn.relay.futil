      mult_pipe1.left = pow1.out;
      mult_pipe1.right = sum1.out;
      mult_pipe1.go = !mult_pipe1.done ? 1'd1;
      m.write_en = mult_pipe1.done;
      m.in = mult_pipe1.out;
      final_multiply[done] = m.done;
    }
    out = m.out;
  }
  control {
    @pos{5} seq {
      @pos{5} init;
      @pos{5} if lt.out with is_negative {
        @pos{5} negate;
      }
      @pos{5} par {
        @pos{5} split_bits_int_x;
        @pos{5} split_bits_frac_x;
      }
      @pos{5} par {
        @pos{5} invoke pow1(base=e.out, integer_exp=int_x.out)();
        @pos{5} invoke pow2(base=frac_x.out, integer_exp=c2.out)();
        @pos{5} invoke pow3(base=frac_x.out, integer_exp=c3.out)();
        @pos{5} invoke pow4(base=frac_x.out, integer_exp=c4.out)();
        @pos{5} invoke pow5(base=frac_x.out, integer_exp=c5.out)();
        @pos{5} invoke pow6(base=frac_x.out, integer_exp=c6.out)();
        @pos{5} invoke pow7(base=frac_x.out, integer_exp=c7.out)();
        @pos{5} invoke pow8(base=frac_x.out, integer_exp=c8.out)();
      }
      @pos{5} par {
        @pos{5} consume_pow2;
        @pos{5} consume_pow3;
        @pos{5} consume_pow4;
        @pos{5} consume_pow5;
        @pos{5} consume_pow6;
        @pos{5} consume_pow7;
        @pos{5} consume_pow8;
      }
      @pos{5} par {
        @pos{5} mult_by_reciprocal_factorial2;
        @pos{5} mult_by_reciprocal_factorial3;
        @pos{5} mult_by_reciprocal_factorial4;
        @pos{5} mult_by_reciprocal_factorial5;
        @pos{5} mult_by_reciprocal_factorial6;
        @pos{5} mult_by_reciprocal_factorial7;
        @pos{5} mult_by_reciprocal_factorial8;
      }
      @pos{5} par {
        @pos{5} sum_round1_1;
        @pos{5} sum_round1_2;
        @pos{5} sum_round1_3;
        @pos{5} sum_round1_4;
      }
      @pos{5} par {
        @pos{5} sum_round2_1;
        @pos{5} sum_round2_2;
      }
      @pos{5} par {
        @pos{5} sum_round3_1;
      }
      @pos{5} add_degree_zero;
      @pos{5} final_multiply;
      @pos{5} if lt.out with is_negative {
        @pos{5} reciprocal;
      }
    }
  }
}
component fp_pow<"pos"={5}>(base: 32, integer_exp: 32) -> (out: 32) {
  cells {
    @pos{5} pow = std_reg(32);
    @pos{5} count = std_reg(32);
    @pos{5} mul = std_fp_smult_pipe(32, 16, 16);
    @pos{5} count_incr_1_1 = std_sadd(32);
    @pos{5} lt_2 = std_slt(32);
  }
  wires {
    group init_pow<"pos"={5}> {
      pow.in = 32'd65536;
      pow.write_en = 1'd1;
      init_pow[done] = pow.done;
    }
    group init_count<"pos"={5}> {
      count.in = 32'd0;
      count.write_en = 1'd1;
      init_count[done] = count.done;
    }
    group execute_mul<"pos"={5}> {
      mul.left = base;
      mul.right = pow.out;
      mul.go = !mul.done ? 1'd1;
      pow.write_en = mul.done;
      pow.in = mul.out;
      execute_mul[done] = pow.done;
    }
    group count_incr_1_1_group<"pos"={5}> {
      count_incr_1_1.left = count.out;
      count_incr_1_1.right = 32'd1;
      count.write_en = 1'd1;
      count.in = count_incr_1_1.out;
      count_incr_1_1_group[done] = count.done;
    }
    comb group lt_2_group<"pos"={5}> {
      lt_2.left = count.out;
      lt_2.right = integer_exp;
    }
    out = pow.out;
  }
  control {
    @pos{5} seq {
      @pos{5} par {
        @pos{5} init_pow;
        @pos{5} init_count;
      }
      @pos{5} while lt_2.out with lt_2_group {
        @pos{5} par {
          @pos{5} execute_mul;
          @pos{5} count_incr_1_1_group;
        }
      }
    }
  }
}
component ln_pade_approx<"pos"={6}>(x: 32) -> (out: 32) {
  cells {
    @pos{6} n1 = std_const(32, 223181);
    @pos{6} n2 = std_const(32, 159435);
    @pos{6} n3 = std_const(32, 382573);
    @pos{6} d2 = std_const(32, 393216);
    @pos{6} d3 = std_const(32, 147456);
    @pos{6} mult_pipe = std_fp_smult_pipe(32, 16, 16);
    @pos{6} n_mult_pipe1 = std_fp_smult_pipe(32, 16, 16);
    @pos{6} n_mult_pipe2 = std_fp_smult_pipe(32, 16, 16);
    @pos{6} d_mult_pipe1 = std_fp_smult_pipe(32, 16, 16);
    @pos{6} d_mult_pipe2 = std_fp_smult_pipe(32, 16, 16);
    @pos{6} div_pipe = std_fp_sdiv_pipe(32, 16, 16);
    @pos{6} add1 = std_fp_sadd(32, 16, 16);
    @pos{6} add2 = std_fp_sadd(32, 16, 16);
    @pos{6} add3 = std_fp_sadd(32, 16, 16);
    @pos{6} sub1 = std_fp_ssub(32, 16, 16);
    @pos{6} num_reg = std_reg(32);
    @pos{6} den_reg = std_reg(32);
    @pos{6} res_reg = std_reg(32);
    @pos{6} x_reg = std_reg(32);
    @pos{6} x_sq_reg = std_reg(32);
  }
  wires {
    group get_x_sq<"pos"={6}> {
      mult_pipe.go = 1'd1;
      mult_pipe.left = x_reg.out;
      mult_pipe.right = x_reg.out;
      get_x_sq[done] = mult_pipe.done;
    }
    group num_term1<"pos"={6}> {
      n_mult_pipe1.go = 1'd1;
      n_mult_pipe1.left = n1.out;
      n_mult_pipe1.right = mult_pipe.out;
      num_term1[done] = n_mult_pipe1.done;
    }
    group num_term2<"pos"={6}> {
      n_mult_pipe2.go = 1'd1;
      n_mult_pipe2.left = n2.out;
      n_mult_pipe2.right = x_reg.out;
      num_term2[done] = n_mult_pipe2.done;
    }
    group den_term2<"pos"={6}> {
      d_mult_pipe2.go = 1'd1;
      d_mult_pipe2.left = d2.out;
      d_mult_pipe2.right = x_reg.out;
      den_term2[done] = d_mult_pipe2.done;
    }
    group write_x_to_reg<"pos"={6}> {
      x_reg.write_en = 1'd1;
      x_reg.in = x;
      write_x_to_reg[done] = x_reg.done;
    }
    group get_numerator<"pos"={6}> {
      add1.left = n_mult_pipe1.out;
      add1.right = n_mult_pipe2.out;
      sub1.left = add1.out;
      sub1.right = n3.out;
      num_reg.in = sub1.out;
      num_reg.write_en = 1'd1;
      get_numerator[done] = num_reg.done;
    }
    group get_denominator<"pos"={6}> {
      add2.left = mult_pipe.out;
      add2.right = d_mult_pipe2.out;
      add3.left = add2.out;
      add3.right = d3.out;
      den_reg.in = add3.out;
      den_reg.write_en = 1'd1;
      get_denominator[done] = den_reg.done;
    }
    group get_res<"pos"={6}> {
      res_reg.write_en = 1'd1;
      res_reg.in = div_pipe.out_quotient;
      get_res[done] = res_reg.done;
    }
    out = res_reg.out;
  }
  control {
    @pos{6} seq {
      @pos{6} write_x_to_reg;
      @pos{6} get_x_sq;
      @pos{6} par {
        @pos{6} num_term1;
        @pos{6} num_term2;
        @pos{6} den_term2;
      }
      @pos{6} par {
        @pos{6} get_numerator;
        @pos{6} get_denominator;
      }
      @pos{6} invoke div_pipe(left=num_reg.out, right=den_reg.out)();
      @pos{6} get_res;
    }
  }
}
component msb_calc<"pos"={6}>(in: 32) -> (count: 32, value: 32) {
  cells {
    @pos{6} reg_1 = std_reg(32);
    @pos{6} reg_2 = std_reg(32);
    @pos{6} reg_3 = std_reg(32);
    @pos{6} reg_4 = std_reg(32);
    @pos{6} reg_5 = std_reg(32);
    @pos{6} rsh_6 = std_rsh(32);
    @pos{6} neq_7 = std_neq(32);
    @pos{6} neq_8 = std_neq(32);
    @pos{6} reg_1_incr_1_9 = std_add(32);
    @pos{6} reg_1_decr_1_10 = std_sub(32);
    @pos{6} rsh_11 = std_rsh(32);
    @pos{6} lsh_12 = std_lsh(32);
    @pos{6} lsh_13 = std_lsh(32);
    @pos{6} lsh_14 = std_lsh(32);
  }
  wires {
    group rsh_6_group<"pos"={6}> {
      rsh_6.left = in;
      rsh_6.right = 32'd16;
      reg_2.write_en = 1'd1;
      reg_2.in = rsh_6.out;
      rsh_6_group[done] = reg_2.done;
    }
    group reg_5_store_to_reg<"pos"={6}> {
      reg_5.in = 32'd1;
      reg_5.write_en = 1'd1;
      reg_5_store_to_reg[done] = reg_5.done;
    }
    comb group neq_7_group<"pos"={6}> {
      neq_7.left = 32'd0;
      neq_7.right = reg_2.out;
    }
    comb group neq_8_group<"pos"={6}> {
      neq_8.left = 32'd0;
      neq_8.right = reg_1.out;
    }
    group reg_1_incr_1_9_group<"pos"={6}> {
      reg_1_incr_1_9.left = reg_1.out;
      reg_1_incr_1_9.right = 32'd1;
      reg_1.write_en = 1'd1;
      reg_1.in = reg_1_incr_1_9.out;
      reg_1_incr_1_9_group[done] = reg_1.done;
    }
    group reg_1_decr_1_10_group<"pos"={6}> {
      reg_1_decr_1_10.left = reg_1.out;
      reg_1_decr_1_10.right = 32'd1;
      reg_1.write_en = 1'd1;
      reg_1.in = reg_1_decr_1_10.out;
      reg_1_decr_1_10_group[done] = reg_1.done;
    }
    group rsh_11_group<"pos"={6}> {
      rsh_11.left = reg_2.out;
      rsh_11.right = 32'd1;
      reg_2.write_en = 1'd1;
      reg_2.in = rsh_11.out;
      rsh_11_group[done] = reg_2.done;
    }
    group lsh_12_group<"pos"={6}> {
      lsh_12.left = reg_5.out;
      lsh_12.right = 32'd1;
      reg_5.write_en = 1'd1;
      reg_5.in = lsh_12.out;
      lsh_12_group[done] = reg_5.done;
    }
    group lsh_13_group<"pos"={6}> {
      lsh_13.left = reg_1.out;
      lsh_13.right = 32'd16;
      reg_3.write_en = 1'd1;
      reg_3.in = lsh_13.out;
      lsh_13_group[done] = reg_3.done;
    }
    group lsh_14_group<"pos"={6}> {
      lsh_14.left = reg_5.out;
      lsh_14.right = 32'd16;
      reg_4.write_en = 1'd1;
      reg_4.in = lsh_14.out;
      lsh_14_group[done] = reg_4.done;
    }
    count = reg_3.out;
    value = reg_4.out;
  }
  control {
    @pos{6} seq {
      @pos{6} rsh_6_group;
      @pos{6} while neq_7.out with neq_7_group {
        @pos{6} seq {
          @pos{6} reg_1_incr_1_9_group;
          @pos{6} rsh_11_group;
        }
      }
      @pos{6} reg_1_decr_1_10_group;
      @pos{6} lsh_13_group;
      @pos{6} reg_5_store_to_reg;
      @pos{6} while neq_8.out with neq_8_group {
        @pos{6} seq {
          @pos{6} reg_1_decr_1_10_group;
          @pos{6} lsh_12_group;
        }
      }
      @pos{6} lsh_14_group;
    }
  }
}
component ln<"pos"={6}>(x: 32) -> (out: 32) {
  cells {
    @pos{6} and1 = std_and(32);
    @pos{6} n = std_reg(32);
    @pos{6} div_pipe = std_fp_sdiv_pipe(32, 16, 16);
    @pos{6} add1 = std_fp_sadd(32, 16, 16);
    @pos{6} mult_pipe = std_fp_smult_pipe(32, 16, 16);
    @pos{6} ln_2 = std_const(32, 45426);
    @pos{6} pade_approx = ln_pade_approx();
    @pos{6} res_reg = std_reg(32);
    @pos{6} msb = msb_calc();
    @pos{6} slice0 = std_slice(32, 16);
    @pos{6} rsh = std_srsh(32);
    @pos{6} shift_amount = std_const(32, 16);
  }
  wires {
    group get_n<"pos"={6}> {
      n.write_en = 1'd1;
      n.in = msb.count;
      get_n[done] = n.done;
    }
    group get_p<"pos"={6}> {
      div_pipe.go = 1'd1;
      div_pipe.left = x;
      div_pipe.right = msb.value;
      get_p[done] = div_pipe.done;
    }
    group get_term1<"pos"={6}> {
      mult_pipe.go = 1'd1;
      mult_pipe.left = ln_2.out;
      mult_pipe.right = n.out;
      get_term1[done] = mult_pipe.done;
    }
    group get_res<"pos"={6}> {
      add1.left = mult_pipe.out;
      add1.right = pade_approx.out;
      res_reg.in = add1.out;
      res_reg.write_en = 1'd1;
      get_res[done] = res_reg.done;
    }
    out = res_reg.out;
  }
  control {
    @pos{6} seq {
      @pos{6} invoke msb(in=x)();
      @pos{6} get_n;
      @pos{6} get_p;
      @pos{6} get_term1;
      @pos{6} invoke pade_approx(x=div_pipe.out_quotient)();
      @pos{6} get_res;
    }
  }
}
component fp_pow_full<"pos"={5}>(base: 32, exp_value: 32) -> (out: 32) {
  cells {
    @pos{5} div = std_fp_sdiv_pipe(32, 16, 16);
    @pos{5} one = std_const(32, 65536);
    @pos{5} zero = std_const(32, 0);
    @pos{5} mult = std_fp_smult_pipe(32, 16, 16);
    @pos{5} new_base = std_reg(32);
    @pos{5} stored_base = std_reg(32);
    @pos{5} res = std_reg(32);
    @pos{5} neg_one = std_const(32, 4294901760);
    @pos{5} lt_1 = std_slt(32);
    @pos{5} new_exp_val = std_reg(32);
    @pos{5} e = exp();
    @pos{5} l = ln();
    @pos{5} lt_2 = std_slt(32);
  }
  wires {
    group rev_base_sign<"pos"={5}> {
      mult.left = new_base.out;
      mult.right = neg_one.out;
      mult.go = !mult.done ? 1'd1;
      new_base.write_en = mult.done;
      new_base.in = mult.out;
      rev_base_sign[done] = new_base.done;
    }
    group rev_res_sign<"pos"={5}> {
      mult.left = res.out;
      mult.right = neg_one.out;
      mult.go = !mult.done ? 1'd1;
      res.write_en = mult.done;
      res.in = mult.out;
      rev_res_sign[done] = res.done;
    }
    comb group lt_1_group<"pos"={5}> {
      lt_1.left = base;
      lt_1.right = zero.out;
    }
    group set_new_exp<"pos"={5}> {
      mult.left = l.out;
      mult.right = exp_value;
      mult.go = !mult.done ? 1'd1;
      new_exp_val.write_en = mult.done;
      new_exp_val.in = mult.out;
      set_new_exp[done] = new_exp_val.done;
    }
    out = res.out;
    group write_to_base_reg<"pos"={5}> {
      new_base.in = base;
      new_base.write_en = 1'd1;
      write_to_base_reg[done] = new_base.done;
    }
    group store_old_reg_val<"pos"={5}> {
      stored_base.in = new_base.out;
      stored_base.write_en = 1'd1;
      store_old_reg_val[done] = stored_base.done;
    }
    group write_e_to_res<"pos"={5}> {
      res.in = e.out;
      res.write_en = 1'd1;
      write_e_to_res[done] = res.done;
    }
    group set_base_reciprocal<"pos"={5}> {
      div.left = one.out;
      div.right = new_base.out;
      div.go = !div.done ? 1'd1;
      new_base.write_en = div.done;
      new_base.in = div.out_quotient;
      set_base_reciprocal[done] = new_base.done;
    }
    group set_res_reciprocal<"pos"={5}> {
      div.left = one.out;
      div.right = res.out;
      div.go = !div.done ? 1'd1;
      res.write_en = div.done;
      res.in = div.out_quotient;
      set_res_reciprocal[done] = res.done;
    }
    comb group lt_2_group<"pos"={5}> {
      lt_2.left = stored_base.out;
      lt_2.right = one.out;
    }
  }
  control {
    @pos{5} seq {
      @pos{5} write_to_base_reg;
      @pos{5} seq {
        @pos{5} if lt_1.out with lt_1_group {
          @pos{5} rev_base_sign;
        }
        @pos{5} store_old_reg_val;
        @pos{5} if lt_2.out with lt_2_group {
          @pos{5} set_base_reciprocal;
        }
      }
      @pos{5} invoke l(x=new_base.out)();
      @pos{5} set_new_exp;
      @pos{5} invoke e(x=new_exp_val.out)();
      @pos{5} write_e_to_res;
      @pos{5} seq {
        @pos{5} if lt_1.out with lt_1_group {
          @pos{5} rev_res_sign;
        }
        @pos{5} if lt_2.out with lt_2_group {
          @pos{5} set_res_reciprocal;
        }
      }
    }
  }
}
component main<"pos"={4}>() -> () {
  cells {
    @external @pos{0} data = seq_mem_d4(32, 1, 3, 2, 2, 1, 2, 2, 2);
    @external @pos{0} x = seq_mem_d4(32, 1, 3, 2, 2, 1, 2, 2, 2);
    @pos{1} lrn_1x3x2x2_ = lrn_1x3x2x2();
  }
  wires {

  }
  control {
    @pos{3} seq {
      @pos{2} @pos(0) invoke lrn_1x3x2x2_[data=data, x=x]()();
    }
  }
}
