component main<"pos"={4}>() -> () {
  cells {
    @external @pos{0} x = seq_mem_d4(32, 2, 4, 1, 1, 2, 3, 1, 1);
    @external @pos{0} x1 = seq_mem_d2(32, 2, 4, 2, 3);
    @pos{1} reshape_2x4_ = reshape_2x4();
  }
  wires {

  }
  control {
    @pos{3} seq {
      @pos{2} @pos(0) invoke reshape_2x4_[x=x, x1=x1]()();
    }
  }
