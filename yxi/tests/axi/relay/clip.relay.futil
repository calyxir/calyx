component main<"pos"={4}>() -> () {
  cells {
    @external @pos{0} x = seq_mem_d3(32, 2, 2, 2, 2, 2, 2);
    @external @pos{0} y = seq_mem_d3(32, 2, 2, 2, 2, 2, 2);
    @pos{1} clip_2x2x2_ = clip_2x2x2();
  }
  wires {

  }
  control {
    @pos{3} seq {
      @pos{2} @pos(0) invoke clip_2x2x2_[x=x, y=y]()();
    }
  }
}
